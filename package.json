{
  "name": "bingyan-badge",
  "version": "2.0.0",
  "type": "module",
  "description": "GitHub 仓库冰岩徽章生成器 - 基于 commit SHA 生成独特的动态 GIF 徽章",
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",

    "test": "tsx src/test.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "gif-encoder-2": "^1.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "sharp": "^0.34.5",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
